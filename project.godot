; Engine configuration file.
; Generated for Hearthside: A Craftsman's Tale — Milestone 1
; Open this file with Godot 4.x to load the project.

config_version=5

[application]

config/name="Hearthside: A Craftsman's Tale"
config/description="A hybrid crafting/management game — Overcooked meets D&D town shop sim."
run/main_scene="res://scenes/shop/forge/ForgeShop.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/managers/GameManager.gd"
DayCycle="*res://scripts/managers/DayCycle.gd"
OrderManager="*res://scripts/managers/OrderManager.gd"
InventoryManager="*res://scripts/managers/InventoryManager.gd"
RecipeDB="*res://scripts/data/RecipeDB.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

